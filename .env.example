# Auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/projects/new

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# M0 local GitHub API token
GITHUB_TOKEN=

# Database (Postgres). For Supabase, use the IPv4 Supavisor session pooler:
#   postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# The direct db.<ref>.supabase.co host is IPv6-only.
DATABASE_URL=

# Queue (Redis). Use rediss:// for TLS providers such as Upstash.
REDIS_URL=

# Object Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI (NVIDIA NIM)
NVIDIA_API_KEY=
NVIDIA_ARCHITECTURE_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_HISTORY_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_SYNTHESIS_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_RISK_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_QA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_REQUEST_TIMEOUT_MS=300000

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_WS_URL=
SOCKET_IO_URL=
SOCKET_IO_PORT=4001
WORKER_CONCURRENCY=2
ARTIFACT_STORAGE_DRIVER=local
ARTIFACT_LOCAL_DIR=artifacts/pipeline
PUPPETEER_EXECUTABLE_PATH=

# M0 spike controls
M0_OWNER=supabase
M0_REPO=supabase
M0_COMMIT_LIMIT=100
M0_PR_LIMIT=50
M0_MAX_TS_FILES=80
M0_MAX_FILE_BYTES=200000
