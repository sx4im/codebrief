{
  "name": "codebrief",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/pipeline",
    "shared/types"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:apply": "tsx packages/pipeline/src/jobs/apply-migrations.ts",
    "db:probe": "tsx packages/pipeline/src/jobs/probe-conn.ts",
    "db:studio": "drizzle-kit studio",
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w packages/pipeline",
    "dev:ws": "npm run dev:ws -w packages/pipeline",
    "m0": "tsx src/m0/run.ts",
    "m0:test-agent-retry": "tsx src/m0/test-agent-retry.ts",
    "m0:test-ast": "tsx src/m0/test-ast.ts",
    "m0:test-risk": "tsx src/m0/test-risk.ts",
    "m0:test-validation": "tsx src/m0/test-source-validation.ts",
    "pipeline:corpus": "tsx packages/pipeline/src/corpus/run-corpus.ts",
    "pipeline:e2e-m2": "tsx packages/pipeline/src/jobs/e2e-m2.ts",
    "pipeline:run-one": "tsx packages/pipeline/src/jobs/run-one.ts",
    "pipeline:diag-corpus": "tsx packages/pipeline/src/jobs/diag-corpus.ts",
    "pipeline:build-demo-briefs": "tsx packages/pipeline/src/jobs/build-demo-briefs.ts",
    "pipeline:verify-briefs": "tsx packages/pipeline/src/gates/verify-briefs.ts",
    "pipeline:test-ast": "tsx packages/pipeline/src/ingestion/test-ast.ts",
    "pipeline:test-deps": "tsx packages/pipeline/src/ingestion/test-deps.ts",
    "pipeline:test-docs": "tsx packages/pipeline/src/ingestion/test-docs.ts",
    "pipeline:test-github-client": "tsx packages/pipeline/src/ingestion/test-github-client.ts",
    "pipeline:test-issues": "tsx packages/pipeline/src/ingestion/test-issues.ts",
    "pipeline:test-tech-stack": "tsx packages/pipeline/src/ingestion/test-tech-stack.ts",
    "pipeline:test-brief-verifier": "tsx packages/pipeline/src/gates/test-verify-briefs.ts",
    "pipeline:test-synthesis-guard": "tsx packages/pipeline/src/test-synthesis-guard.ts",
    "pipeline:test-token-usage": "tsx packages/pipeline/src/adapters/test-token-usage.ts",
    "pipeline:test-static-analysis": "tsx packages/pipeline/src/analysis/test-static-analysis.ts",
    "pipeline:test-repo-stats": "tsx packages/pipeline/src/analysis/test-repo-stats.ts",
    "pipeline:test-recency": "tsx packages/pipeline/src/analysis/test-recency.ts",
    "pipeline:test-diagram": "tsx packages/pipeline/src/output/test-diagram.ts",
    "pipeline:test-analysis-job": "tsx packages/pipeline/src/jobs/test-analysis-job.ts",
    "web:test-export-format": "cd apps/web && node --conditions=react-server --import tsx lib/analysis/test-export-format.ts",
    "web:test-artifact-upload": "cd apps/web && node --conditions=react-server --import tsx lib/storage/test-analysis-artifacts.ts",
    "web:test-qa-grounding": "cd apps/web && node --conditions=react-server --import tsx lib/ai/test-qa-grounding.ts",
    "web:test-pdf-export": "cd apps/web && node --conditions=react-server --import tsx lib/analysis/test-pdf-export.ts",
    "web:test-brief-roundtrip": "cd apps/web && node --conditions=react-server --import tsx lib/analysis/test-brief-roundtrip.ts",
    "test": "npm run m0:test-validation && npm run m0:test-ast && npm run m0:test-risk && npm run m0:test-agent-retry && npm run pipeline:test-synthesis-guard && npm run pipeline:test-token-usage && npm run pipeline:test-static-analysis && npm run pipeline:test-repo-stats && npm run pipeline:test-recency && npm run pipeline:test-diagram && npm run pipeline:test-analysis-job && npm run pipeline:test-brief-verifier && npm run pipeline:test-github-client && npm run pipeline:test-ast && npm run pipeline:test-deps && npm run pipeline:test-docs && npm run pipeline:test-issues && npm run pipeline:test-tech-stack && npm run web:test-export-format && npm run web:test-artifact-upload && npm run web:test-qa-grounding && npm run web:test-pdf-export && npm run web:test-brief-roundtrip",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@clerk/nextjs": "6.39.5",
    "bullmq": "^5.34.4",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "puppeteer-core": "^23.10.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.24.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.28.1"
    },
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
